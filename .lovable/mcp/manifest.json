{
  "version": 1,
  "sdk_version": "0.23.0",
  "path": "/functions/v1/mcp",
  "auth": {
    "type": "oauth",
    "issuer": "https://mqeqopnzopriuzckjjiz.supabase.co/auth/v1",
    "accepted_audiences": [
      "authenticated"
    ]
  },
  "mcp": {
    "server": {
      "name": "stockist-mcp",
      "version": "0.1.0",
      "title": "Stockist MCP"
    },
    "tools": [
      {
        "name": "list_items",
        "title": "List inventory items",
        "description": "List all items in the master product catalog (name, category, unit).",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "search": {
              "description": "Optional case-insensitive substring to filter item names.",
              "type": "string"
            }
          }
        },
        "outputSchema": null
      },
      {
        "name": "list_daily_stock_sheets",
        "title": "List daily stock sheet entries",
        "description": "List daily stock sheet entries. RLS restricts results to the caller's assigned teams (admins see all).",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "start_date": {
              "description": "Filter entries on or after this ISO date (YYYY-MM-DD).",
              "type": "string"
            },
            "end_date": {
              "description": "Filter entries on or before this ISO date (YYYY-MM-DD).",
              "type": "string"
            },
            "team_member": {
              "description": "Filter by retail team member name.",
              "type": "string"
            },
            "limit": {
              "default": 100,
              "type": "integer",
              "exclusiveMinimum": 0,
              "maximum": 500
            }
          }
        },
        "outputSchema": null
      },
      {
        "name": "list_issuance",
        "title": "List issuance ledger",
        "description": "List items issued to recipient groups (Retail, Housekeeping, Managers, Cube, Bar).",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "start_date": {
              "type": "string"
            },
            "end_date": {
              "type": "string"
            },
            "recipient_group": {
              "type": "string"
            },
            "limit": {
              "default": 100,
              "type": "integer",
              "exclusiveMinimum": 0,
              "maximum": 500
            }
          }
        },
        "outputSchema": null
      },
      {
        "name": "list_transfers",
        "title": "List transfer ledger",
        "description": "List items transferred to other branches/businesses.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "start_date": {
              "type": "string"
            },
            "end_date": {
              "type": "string"
            },
            "destination": {
              "type": "string"
            },
            "limit": {
              "default": 100,
              "type": "integer",
              "exclusiveMinimum": 0,
              "maximum": 500
            }
          }
        },
        "outputSchema": null
      },
      {
        "name": "list_received",
        "title": "List received ledger",
        "description": "List items received from suppliers.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "start_date": {
              "type": "string"
            },
            "end_date": {
              "type": "string"
            },
            "supplier": {
              "type": "string"
            },
            "limit": {
              "default": 100,
              "type": "integer",
              "exclusiveMinimum": 0,
              "maximum": 500
            }
          }
        },
        "outputSchema": null
      },
      {
        "name": "list_weekly_stock_counts",
        "title": "List weekly stock counts",
        "description": "List physical stock counts by location (Main Store, 24hr Store, Cube).",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "start_date": {
              "type": "string"
            },
            "end_date": {
              "type": "string"
            },
            "location": {
              "type": "string"
            },
            "limit": {
              "default": 100,
              "type": "integer",
              "exclusiveMinimum": 0,
              "maximum": 500
            }
          }
        },
        "outputSchema": null
      },
      {
        "name": "record_issuance",
        "title": "Record an issuance",
        "description": "Record items issued to a recipient group. Requires an existing item id.",
        "annotations": {
          "readOnlyHint": false,
          "destructiveHint": false,
          "idempotentHint": false,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "date": {
              "type": "string",
              "description": "ISO date (YYYY-MM-DD)."
            },
            "recipient_group": {
              "type": "string",
              "enum": [
                "Retail",
                "Housekeeping",
                "Managers",
                "Cube",
                "Bar"
              ],
              "description": "Recipient group receiving the issuance."
            },
            "item_id": {
              "type": "string",
              "format": "uuid",
              "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$",
              "description": "Item id from list_items."
            },
            "quantity": {
              "type": "number",
              "exclusiveMinimum": 0
            }
          },
          "required": [
            "date",
            "recipient_group",
            "item_id",
            "quantity"
          ]
        },
        "outputSchema": null
      },
      {
        "name": "record_received",
        "title": "Record a receipt from a supplier",
        "description": "Record items received from a supplier. Requires an existing item id.",
        "annotations": {
          "readOnlyHint": false,
          "destructiveHint": false,
          "idempotentHint": false,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "date": {
              "type": "string",
              "description": "ISO date (YYYY-MM-DD)."
            },
            "supplier": {
              "type": "string",
              "minLength": 1
            },
            "item_id": {
              "type": "string",
              "format": "uuid",
              "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$"
            },
            "quantity": {
              "type": "number",
              "exclusiveMinimum": 0
            },
            "invoice_number": {
              "type": "string"
            }
          },
          "required": [
            "date",
            "supplier",
            "item_id",
            "quantity"
          ]
        },
        "outputSchema": null
      },
      {
        "name": "record_transfer",
        "title": "Record a transfer",
        "description": "Record items transferred to another branch or business.",
        "annotations": {
          "readOnlyHint": false,
          "destructiveHint": false,
          "idempotentHint": false,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "date": {
              "type": "string",
              "description": "ISO date (YYYY-MM-DD)."
            },
            "destination": {
              "type": "string",
              "minLength": 1
            },
            "item_id": {
              "type": "string",
              "format": "uuid",
              "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$"
            },
            "quantity": {
              "type": "number",
              "exclusiveMinimum": 0
            },
            "reason": {
              "type": "string"
            }
          },
          "required": [
            "date",
            "destination",
            "item_id",
            "quantity"
          ]
        },
        "outputSchema": null
      }
    ]
  }
}
